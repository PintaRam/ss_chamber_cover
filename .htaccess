# Enable Rewrite Engine
RewriteEngine On
RewriteBase /

# Remove trailing slashes
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)/$ /$1 [L,R=301]

# SEO-Friendly URL Redirects - Rewrite clean URLs to actual files

# Homepage
RewriteRule ^stainless-steel-chamber-cover/?$ index.html [L,NC]

# About Us
RewriteRule ^about-shree-ashish-industries/?$ HTML/aboutUs.html [L,NC]

# SS Products
RewriteRule ^stainless-steel-access-cover/?$ HTML/ssacesscover.html [L,NC]
RewriteRule ^laksh-influence-chamber-cover/?$ HTML/SSLakshCover.html [L,NC]
RewriteRule ^recessed-chamber-cover/?$ HTML/ssrecessedcover.html [L,NC]
RewriteRule ^stainless-steel-chequered-cover/?$ HTML/sschequeredcover.html [L,NC]

# FRP Products
RewriteRule ^frp-manhole-cover-5-ton/?$ HTML/frp5ton.html [L,NC]
RewriteRule ^frp-manhole-cover-10-ton/?$ HTML/frp10ton.html [L,NC]
RewriteRule ^frp-manhole-cover-25-ton/?$ HTML/frp25ton.html [L,NC]
RewriteRule ^frp-gully-cover/?$ HTML/frpgullycover.html [L,NC]

# Gallery & Contact
RewriteRule ^chamber-cover-gallery/?$ HTML/gallery.html [L,NC]
RewriteRule ^contact-us/?$ HTML/contact.html [L,NC]

# 301 Redirects - Old URLs to New SEO URLs (Permanent Redirects)
RedirectMatch 301 ^/index\.html$ /stainless-steel-chamber-cover
RedirectMatch 301 ^/HTML/aboutUs\.html$ /about-shree-ashish-industries
RedirectMatch 301 ^/HTML/ssacesscover\.html$ /stainless-steel-access-cover
RedirectMatch 301 ^/HTML/SSLakshCover\.html$ /laksh-influence-chamber-cover
RedirectMatch 301 ^/HTML/ssrecessedcover\.html$ /recessed-chamber-cover
RedirectMatch 301 ^/HTML/sschequeredcover\.html$ /stainless-steel-chequered-cover
RedirectMatch 301 ^/HTML/frp5ton\.html$ /frp-manhole-cover-5-ton
RedirectMatch 301 ^/HTML/frp10ton\.html$ /frp-manhole-cover-10-ton
RedirectMatch 301 ^/HTML/frp25ton\.html$ /frp-manhole-cover-25-ton
RedirectMatch 301 ^/HTML/frpgullycover\.html$ /frp-gully-cover
RedirectMatch 301 ^/HTML/gallery\.html$ /chamber-cover-gallery
RedirectMatch 301 ^/HTML/contact\.html$ /contact-us

# GZIP Compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# Browser Caching
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType text/javascript "access plus 1 month"
</IfModule>

# Security Headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
</IfModule>

# Custom Error Pages (optional)
ErrorDocument 404 /index.html
